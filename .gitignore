# Claude Code local settings
.claude/settings.local.json

# Build artifacts
build/
# ...and an alternate BUILD dir. Verifying asmspy from a MOUNTED host `make cli` is a
# known trap (it reuses a Capstone-less disasm.o and yields silent `(?)` symbols), so the
# documented workarounds are `make docker-cli` or a fresh dir — `make cli BUILD=build-x`.
# Without this, that documented workflow leaves an untracked tree for `git add -A` to sweep.
build-*/

# Generated packaging artifacts (Track B)
asmtest.pc
asmtest_single.h

# Generated bindings-substrate artifacts (Track 0)
asmtest-emu.pc
asmtest_abi.json
asmtest_abi_win64.json
bindings/conformance/corpus.json

# Python binding artifacts (Track P)
__pycache__/
*.py[cod]
.pytest_cache/
*.egg-info/

# Rust binding artifacts (Track R)
bindings/rust/target/
bindings/rust/Cargo.lock

# Zig binding artifacts (Track Z)
bindings/zig/.zig-cache/
bindings/zig/zig-out/

# Managed example workload build artifacts (taint tier dotnet lanes)
examples/**/obj/
examples/**/bin/

# Node / .NET binding artifacts (Tracks N, D)
bindings/node/node_modules/
bindings/node/package-lock.json
bindings/dotnet/bin/
bindings/dotnet/obj/
bindings/dotnet/**/bin/
bindings/dotnet/**/obj/

# Java binding artifacts (Maven)
bindings/java/target/

# Coverage / analysis artifacts (Track D)
*.gcov
*.gcno
*.gcda
*.plist

# Sphinx documentation build output
docs/_build/

# Packaging native payloads + artifacts staged by `make <lang>-package`
bindings/python/asmtest/_libs/
bindings/ruby/native/
bindings/lua/native/
bindings/node/native/
bindings/java/src/main/resources/native/
bindings/dotnet/runtimes/
bindings/dotnet/lib/
bindings/**/*.gem

# macOS Finder metadata
.DS_Store

# V8 isolate logs from the hwtrace-jit lane (node --perf-basic-prof)
isolate-*.log

# .NET build artifacts from the examples/dotnet demo projects (incl. jit_dotnet)
examples/dotnet/**/obj/
examples/dotnet/**/bin/
