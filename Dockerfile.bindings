# Dockerfile.bindings — test the language wrappers in one reproducible image.
#
# Builds an image with every wrapper's toolchain (Python + pytest, a C++
# compiler, Rust/cargo) plus libunicorn, so the per-language binding tests run
# the same way on any host — including languages not installed locally. This is
# how `make docker-python` / `docker-cpp` / `docker-rust` / `docker-bindings`
# verify the wrappers; CI uses the same recipe.
#
# Build:  docker build -f Dockerfile.bindings -t asmtest-bindings .
# Run:    docker run --rm asmtest-bindings              # -> all wrapper tests
#         docker run --rm asmtest-bindings make rust-test
# Or via the Makefile: `make docker-bindings`, `make docker-rust`, ...
#
# x86-64 natively; aarch64 via `--platform linux/arm64`. The emulator's x86-64
# guest cases self-gate to an x86-64 host (as in the C `emu` suite).

ARG BASE=ubuntu:24.04
FROM ${BASE}

ENV DEBIAN_FRONTEND=noninteractive

# Per-language toolchains: C/C++ (build-essential), Python + pytest, Rust/cargo.
# pkg-config is handy for the C++ consumption path. No crates.io access is needed
# at build/test time — the Rust binding has no external dependencies.
RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      build-essential ca-certificates pkg-config \
      python3 python3-pytest \
      cargo rustc \
      curl xz-utils \
 && rm -rf /var/lib/apt/lists/*

# Zig has no apt package: fetch the official release tarball for the build arch
# (uname -m → x86_64 / aarch64, matching ziglang.org's naming).
ARG ZIG_VERSION=0.13.0
RUN set -eux; \
    arch="$(uname -m)"; \
    url="https://ziglang.org/download/${ZIG_VERSION}/zig-linux-${arch}-${ZIG_VERSION}.tar.xz"; \
    curl -fsSL "$url" -o /tmp/zig.tar.xz; \
    mkdir -p /opt/zig; \
    tar -xJf /tmp/zig.tar.xz -C /opt/zig --strip-components=1; \
    rm /tmp/zig.tar.xz; \
    ln -s /opt/zig/zig /usr/local/bin/zig; \
    zig version

WORKDIR /src

# Install the optional emulator dependency (libunicorn) first, from just the
# Makefile + installer, so this slow layer stays cached when sources change.
COPY Makefile ./
COPY scripts/ ./scripts/
RUN make deps DEPS_ARGS=--emu && rm -rf /var/lib/apt/lists/*

# The rest of the tree (build artifacts excluded via .dockerignore).
COPY . .

# Default goal: run every wrapper's test over the conformance corpus.
CMD ["sh", "-c", "make python-test && make cpp-test && make rust-test && make zig-test"]
