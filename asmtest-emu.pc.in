prefix=@PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include/asmtest

Name: asmtest-emu
Description: asm-test emulator tier (Unicorn) plus the Keystone assembler and Capstone disassembler — the full superset shared library
URL: https://github.com/wilvk/asm-test
Version: @VERSION@
Libs: -L${libdir} -lasmtest_emu
Libs.private: -lunicorn -lkeystone -lcapstone
Cflags: -I${includedir}
