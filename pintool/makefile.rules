# pintool/makefile.rules — declares the tool the kit's default rules build.
#
# The kit's makefile.default.rules turns each name in TEST_TOOL_ROOTS into a
# obj-intel64/<name>.so target compiled from <name>.cpp under PinCRT. We ship two
# tools:
#   - asmtest_pintool  (PIN-2, XED-decoded offset trace) — fills the repo's shared
#     asmtest_trace_t offset model over POSIX shm (pintool_shm.h).
#   - probe_capture    (PIN-3, probe-mode arg/return capture) — fills at_val_rec_t
#     records over POSIX shm (include/asmtest_valtrace_shm.h). Needs the repo
#     include/ dir, reached via -I../include below (the kit compiles from this
#     directory). No extra apps/objects/libs.
TEST_TOOL_ROOTS := asmtest_pintool probe_capture

# pintool_shm.h lives beside the tool source (deliberately NOT under include/ —
# PIN-2 ships no public header); -I. reaches it. probe_capture additionally reads
# include/asmtest_valtrace_shm.h + asmtest_valtrace.h + asmtest_trace.h, reached via
# -I../include (harmless to asmtest_pintool, which does not include them).
TOOL_CXXFLAGS += -I. -I../include
