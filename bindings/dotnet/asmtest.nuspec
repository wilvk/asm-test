<?xml version="1.0" encoding="utf-8"?>
<!-- NuGet manifest for the asm-test .NET binding (P/Invoke). The package exposes
     the reusable library assembly AsmTest.dll (built from Asmtest.cs by
     asmtest-lib.csproj) — NOT the conformance runner — plus the prebuilt
     libasmtest_emu in the runtimes/<rid>/native/ layout the .NET loader resolves
     automatically. `make dotnet-package` builds the lib and stages a
     runtimes/<rid>/native/ slot per platform present in build/dist/native/ (see
     docs/packaging.md). -->
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>AsmTest</id>
    <version>1.0.0</version>
    <authors>asm-test contributors</authors>
    <license type="expression">MIT</license>
    <projectUrl>https://github.com/wilvk/asm-test</projectUrl>
    <description>.NET binding for the asm-test assembly unit-testing framework:
      run, capture, and emulate assembly routines via P/Invoke over the
      opaque-handle binding ABI. The emulator native lib links libunicorn.</description>
    <tags>assembly testing abi emulator unicorn pinvoke</tags>
  </metadata>
  <files>
    <!-- The reusable library assembly (asmtest-lib.csproj -> AsmTest.dll). -->
    <file src="lib/**/*.dll" target="lib" />
    <!-- The native payload, populated by `make dotnet-package` from
         build/dist/native/. One runtimes/<rid>/native/ entry per platform. -->
    <file src="runtimes/**/native/*" target="runtimes" />
  </files>
</package>
