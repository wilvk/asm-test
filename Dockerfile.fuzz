# Dockerfile.fuzz — external-engine fuzzing shim lane (libFuzzer + AFL++).
#
# The Track E shim exposes the emulator's basic-block coverage to an industrial
# fuzzer (libFuzzer / AFL++) without compiler-instrumenting the guest bytes (they
# run under Unicorn). clang and afl++ are apt-installable, so per CLAUDE.md they
# are added HERE — the lane where the work runs — rather than gated away: this
# image builds every harness and `docker-fuzz` runs `make fuzz-shim-test`, which
# fails unless both engines FIND their planted crash. There is no self-skip: the
# shim is genuinely exercised, not a demand-gated stub.
#
# FROM asmtest-bindings-base: it already carries the C toolchain + libunicorn +
# libcapstone (the emulator tier the harnesses link against). This layer adds:
#   clang               1:18.0-59~exp2      (libFuzzer: -fsanitize=fuzzer)
#   libclang-rt-18-dev  1:18.1.3-1ubuntu1   (libclang_rt.fuzzer runtime + main)
#   afl++               4.09c-1ubuntu3      (afl-clang-fast, afl-fuzz, libAFLDriver.a)
# Versions are the ubuntu:24.04 (noble) pinned-archive candidates as of authoring;
# the base image pins the archive, so they are reproducible without a digest line
# (clang/afl++ come from apt, not a tarball fetch — see the doc's Pinning note).
# Linux x86-64 lane (the guest is x86-64 machine code run under Unicorn).

ARG BASE_IMAGE=asmtest-bindings-base
FROM ${BASE_IMAGE}

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
 && apt-get install -y --no-install-recommends \
      clang libclang-rt-18-dev afl++ \
 && rm -rf /var/lib/apt/lists/*

# The whole tree (build artifacts excluded via .dockerignore). The bindings-base
# WORKDIR is already /src.
COPY . .

# Default: build the harnesses and run the bounded libFuzzer + AFL smokes, each
# asserting its engine finds the planted crash. AFL wants these so it does not
# abort on the container's cpufreq/core-pattern settings (also passed by the
# docker-fuzz rule's `docker run -e`, belt and suspenders).
ENV AFL_SKIP_CPUFREQ=1 AFL_I_DONT_CARE_ABOUT_MISSING_CRASHES=1
CMD ["make", "fuzz-shim-test"]
