# Dockerfile.cli — the asmspy CLI (cli/): an ncurses front-end over the
# out-of-process tracer. Built on the bindings base (C toolchain + Capstone),
# adding libipt-dev (the hwtrace tier's PT decoder build dep, like the hwtrace
# image) and libncurses-dev (the ncursesw dev files the TUI links). Runs the
# headless smoke by default; interactive use is `docker run -it asmtest-cli bash`
# then `./build/asmspy`.
#
# gcc-multilib supplies the 32-bit libc/startup files (`gcc -m32`), which the
# smoke needs to build cli/i386_victim — a REAL i386 tracee for the EI_CLASS
# refusal check (asmspy-plan Theme F3). Without it that lane could only
# self-skip, and per CLAUDE.md a test that can only ever self-skip is not a test:
# "no lane can test it" would be a fact about this image, not about the feature.
# A 32-bit process is not hardware, so it is not a real gate — it is an apt line.
# Version pin: the distro package, resolved against this image's pinned Ubuntu
# base and its gcc (13.3.0) — gcc-multilib is a metapackage that must match the
# gcc already installed here, so pinning it independently would only be able to
# conflict with it. Same discipline as libipt-dev / libncurses-dev above.
ARG BASE_IMAGE=asmtest-bindings-base
FROM ${BASE_IMAGE}
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
 && apt-get install -y --no-install-recommends libipt-dev libncurses-dev \
      gcc-multilib \
 && rm -rf /var/lib/apt/lists/*
COPY . .
CMD sh -c 'make cli-smoke'
