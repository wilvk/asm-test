<Project Sdk="Microsoft.NET.Sdk">

  <!-- Code working-set + locality: distinct 4 KB pages the window touched and a jump-distance
       histogram, straight from AsmTrace.Addresses arithmetic. Dependency-free: compiles the
       binding source (HwTrace.cs) directly and P/Invokes libasmtest_hwtrace — no NuGet, so
       `dotnet run` works offline. Run by `make hwtrace-dotnet-example`; self-skips (exit 0) where
       single-step can't run. EnableDefaultCompileItems=false so it compiles exactly Program.cs +
       Report.cs + the one binding source. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>footprint</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
    <Deterministic>true</Deterministic>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="Report.cs" />
    <Compile Include="../../../bindings/dotnet/hwtrace/HwTrace.cs" />
  </ItemGroup>

</Project>
