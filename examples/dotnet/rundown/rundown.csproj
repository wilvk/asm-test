<Project Sdk="Microsoft.NET.Sdk">

  <!-- §D0.2 demo: name WARM methods too, via an in-process perf-map rundown
       (AsmTrace withRundown: true / DiagnosticsIpc). Dependency-free — compiles the
       binding source (HwTrace.cs) directly and P/Invokes libasmtest_hwtrace, no NuGet,
       so `dotnet run` works offline. Run by `make hwtrace-dotnet-example`; self-skips
       (exit 0) where single-step / diagnostics are unavailable.

       EnableDefaultCompileItems=false so it compiles exactly Program.cs + Report.cs + the one
       binding source (never globbing sibling examples or the binding's own Main). -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>rundown</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
    <Deterministic>true</Deterministic>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="Report.cs" />
    <Compile Include="../../../bindings/dotnet/hwtrace/HwTrace.cs" />
  </ItemGroup>

</Project>
