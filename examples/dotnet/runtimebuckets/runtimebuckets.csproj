<Project Sdk="Microsoft.NET.Sdk">

  <!-- Name the ~1M-instruction runtime lump by MODULE: HwTrace.SymbolizeBuckets over a
       whole-window scope's captured addresses (P/Invokes asmtest_hwtrace_symbolize_bucket,
       post-close safe). Dependency-free: compiles the binding source (HwTrace.cs) directly and
       P/Invokes libasmtest_hwtrace — no NuGet, so `dotnet run` works offline. Run by
       `make hwtrace-dotnet-example`; self-skips (exit 0) where single-step can't run.
       EnableDefaultCompileItems=false so it compiles exactly Program.cs + Report.cs + the one
       binding source. -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>runtimebuckets</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
    <Deterministic>true</Deterministic>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="Report.cs" />
    <Compile Include="../../../bindings/dotnet/hwtrace/HwTrace.cs" />
  </ItemGroup>

</Project>
