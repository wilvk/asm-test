<Project Sdk="Microsoft.NET.Sdk">

  <!-- §E1 hybrid whole-window demo: AsmTrace.WindowHybrid runs the cheap statistical
       AMD-LBR survey (WindowHot) to find the hot methods, then runs the exact
       out-of-process window (Window) publishing ONLY the hot methods' regions — so the
       per-instruction stepper is spent on the hot managed slice and the cold remainder is
       elided. Dependency-free: compiles the binding source (HwTrace.cs) directly, no NuGet,
       so `dotnet run` works offline. Run by `make hwtrace-dotnet-example`.

       DEGRADES cleanly: off Zen 3+/LBR or without CAP_PERFMON (the plain example lane) the
       survey self-skips and this falls back to a full exact Window; where ptrace is refused
       the window self-skips (exit 0) — a docker-hwtrace-amd-style permissioned lane on a Zen
       host runs the full hybrid live.

       EnableDefaultCompileItems=false so it compiles exactly Program.cs + the one binding
       source (never globbing sibling examples or the binding's own Main). -->
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>windowhybrid</AssemblyName>
    <InvariantGlobalization>true</InvariantGlobalization>
    <Deterministic>true</Deterministic>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <AllowUnsafeBlocks>false</AllowUnsafeBlocks>
    <!-- The survey needs a LONG hot loop (native speed) to collect samples, but pass 2
         single-steps it — and a Tier0 hot loop would trip OSR / tier-up mid-window, re-JITting
         under single-step and aborting (the documented per-step footgun). Disable tiered
         compilation so the block's methods JIT ONCE, upfront, and never re-JIT inside the exact
         window. (A real caller with a modest hot loop needs no such knob.) -->
    <TieredCompilation>false</TieredCompilation>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="Program.cs" />
    <Compile Include="../../../bindings/dotnet/hwtrace/HwTrace.cs" />
  </ItemGroup>

</Project>
