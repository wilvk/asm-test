<!-- Attach harness for F4 increment 1 (live GC-move canonicalization on the ptrace live-attach
     tier): drives Microsoft.Diagnostics.NETCore.Client's DiagnosticsClient.AttachProfiler against a
     running victim's pid over the dotnet-diagnostic-<pid> socket, BEFORE the ptrace tracer attaches.
     Needs a nuget restore (the docker lane has network at build time).
     See mk/native-trace.mk `gccanon-attach`. -->
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>gccanon_attacher</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Diagnostics.NETCore.Client" Version="0.2.510501" />
  </ItemGroup>
</Project>
