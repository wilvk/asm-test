# Keep the build context small and the image free of host artifacts, so a
# `docker build` always starts from a clean tree (mirrors a fresh CI checkout).
.git/
.github/
.claude/
build/

# Generated packaging / coverage / analysis artifacts (see .gitignore).
asmtest.pc
asmtest-emu.pc
asmtest_single.h
asmtest_abi.json
bindings/conformance/corpus.json
*.gcov
*.gcno
*.gcda
*.plist

# Binding build artifacts (rebuilt inside the image).
**/__pycache__/
**/.pytest_cache/
bindings/rust/target/
bindings/rust/Cargo.lock

# This image and its setup don't need to be in the context.
Dockerfile
Dockerfile.bindings
.dockerignore
