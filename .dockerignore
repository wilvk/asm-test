# Keep the build context small and the image free of host artifacts, so a
# `docker build` always starts from a clean tree (mirrors a fresh CI checkout).
.git/
.github/
.claude/
build/

# Generated packaging / coverage / analysis artifacts (see .gitignore).
asmtest.pc
asmtest-emu.pc
asmtest_single.h
asmtest_abi.json
bindings/conformance/corpus.json
*.gcov
*.gcno
*.gcda
*.plist

# Binding build artifacts (rebuilt inside the image).
**/__pycache__/
**/.pytest_cache/
bindings/rust/target/
bindings/rust/Cargo.lock
bindings/zig/.zig-cache/
bindings/zig/zig-out/
bindings/node/node_modules/
bindings/dotnet/bin/
bindings/dotnet/obj/

# Dockerfiles are read via -f (not from the context) — keep them out of images.
Dockerfile
Dockerfile.bindings-base
bindings/*/Dockerfile
.dockerignore
